{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "link[referrerpolicy]"
        ]
      }
    ],
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off",
        "link-name": "off"
      }
    ],
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "scroll-margin-top",
          "scroll-behavior",
          "scroll-behavior: smooth"
        ]
      }
    ],
    "disown-opener": "off"
  }
}